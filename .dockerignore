node_modules
# Exclude almost all of .git (3GB) but keep the tiny files needed to resolve HEAD.
# write-build-info.cjs reads these directly (no git binary required) to stamp the
# real commit hash into build-info.json during the Docker build.
.git
!.git/HEAD
!.git/refs
!.git/refs/**
!.git/packed-refs
.github
dist/index.js
dist/index.js.map
.env
.env.local
.env.*.local
.cache
.idea
.vscode
.DS_Store
android/
ios/
/public/videos/
*.zip
*.tar.gz
*.aab
*.apk
*.ipa
backups/
tmp/
.local/
coverage
.nyc_output
zi[A-Za-z0-9]*
npm-debug.log
CAREN-xcode-project.zip
