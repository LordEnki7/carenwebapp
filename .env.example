# C.A.R.E.N. Platform Environment Variables Template
# Copy this to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database_name

# Authentication Secrets (generate random strings)
SESSION_SECRET=your_random_session_secret_minimum_32_characters
CUSTOM_DOMAIN_SECRET=your_custom_domain_secret_for_tokens

# Email Configuration (Gmail SMTP for notifications)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_gmail_app_specific_password

# SMS Configuration (TextBelt for emergency alerts)
TEXTBELT_API_KEY=your_textbelt_api_key_from_textbelt_com

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Admin Dashboard Access
CAREN_ADMIN_2025_PRODUCTION=your_secure_admin_access_key

# Application Mode
NODE_ENV=development

# Optional: Custom Domain Configuration
REPLIT_DOMAIN=your-replit-app-name.replit.app
CUSTOM_DOMAIN=your-custom-domain.com

# Security Settings
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW_MS=900000

# AI Services (if using AI features)
OPENAI_API_KEY=your_openai_api_key_if_needed
ANTHROPIC_API_KEY=your_anthropic_api_key_if_needed

# Optional: Google OAuth (for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_from_google_cloud_console
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_from_google_cloud_console

# Firebase Configuration (for web crashlytics and analytics)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_from_firebase_console
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id