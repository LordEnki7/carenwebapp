<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
        <key>CFBundleDisplayName</key>
        <string>CAREN Alert</string>
        <key>CFBundleIdentifier</key>
        <string>com.caren.safetyapp</string>
        <key>CFBundleName</key>
        <string>CAREN Alert</string>
        <key>CFBundleShortVersionString</key>
        <string>1.0.0</string>
        <key>CFBundleVersion</key>
        <string>3</string>
        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>
        <key>CFBundlePackageType</key>
        <string>APPL</string>
        <key>CFBundleDevelopmentRegion</key>
        <string>en</string>
        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>
        <key>LSRequiresIPhoneOS</key>
        <true/>
        <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>
        <key>UIRequiredDeviceCapabilities</key>
        <array>
                <string>armv7</string>
        </array>
        <key>UISupportedInterfaceOrientations</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
        </array>
        <key>NSCameraUsageDescription</key>
        <string>CAREN uses your camera to record video evidence during incidents and police encounters.</string>
        <key>NSMicrophoneUsageDescription</key>
        <string>CAREN records audio during emergencies and police encounters as legal evidence.</string>
        <key>NSLocationWhenInUseUsageDescription</key>
        <string>CAREN uses your location to identify your state and display the correct legal rights.</string>
        <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
        <string>CAREN monitors your location to automatically detect emergencies and provide real-time legal protection.</string>
        <key>NSPhotoLibraryUsageDescription</key>
        <string>CAREN saves recorded video evidence to your photo library for safekeeping.</string>
        <key>NSPhotoLibraryAddUsageDescription</key>
        <string>CAREN saves incident recordings and evidence to your photo library.</string>
        <key>NSSpeechRecognitionUsageDescription</key>
        <string>CAREN uses voice recognition for hands-free emergency activation and voice commands.</string>
        <key>NSContactsUsageDescription</key>
        <string>CAREN accesses contacts to send emergency alerts to your designated family members.</string>
        <key>UIBackgroundModes</key>
        <array>
                <string>location</string>
                <string>audio</string>
                <string>remote-notification</string>
                <string>fetch</string>
        </array>
        <key>NSHumanReadableCopyright</key>
        <string>Copyright © 2025 CAREN Alert. All rights reserved.</string>
</dict>
</plist>
