modules = ["nodejs-20", "web", "java-17", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["zip", "unzip", "glib", "nss", "dbus", "atk", "cups", "gtk3", "mesa", "expat", "alsa-lib", "cairo", "fontconfig", "freetype", "pango", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXrandr", "libxkbcommon", "at-spi2-atk", "at-spi2-core", "libuuid", "imagemagick", "openjdk17", "ffmpeg", "rsync"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "server-health"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "video-stream"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-deployment"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsc --noEmit 2>&1 | head -50"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "server-health"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
sleep 2
      BASE=\"http://localhost:5000\"
      PASS=0; FAIL=0
      check() {
        STATUS=$(curl -s -o /dev/null -w \"%{http_code}\" --max-time 5 \"$1\")
        if [ \"$STATUS\" -ge 200 ] && [ \"$STATUS\" -lt 500 ]; then
          echo \"PASS [$STATUS] $1\"; PASS=$((PASS+1))
        else
          echo \"FAIL [$STATUS] $1\"; FAIL=$((FAIL+1))
        fi
      }
      check \"$BASE/api/auth/user\"
      check \"$BASE/caren-hero.mp4\"
      check \"$BASE/caren-short.mp4\"
      check \"$BASE/api/subscription-plans\"
      echo \"---\"
      echo \"Results: $PASS passed, $FAIL failed\"
      [ \"$FAIL\" -eq 0 ]"""

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "video-stream"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check-videos.sh"

[[workflows.workflow]]
name = "check-deployment"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check-deployment.sh"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[agent]
integrations = ["javascript_database:1.0.0", "javascript_log_in_with_replit:1.0.0", "javascript_stripe:1.0.0", "javascript_sendgrid:1.0.0", "javascript_openai_ai_integrations:1.0.0"]

